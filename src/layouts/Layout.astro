---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Alberto Cavedon — Speleologo subacqueo di fama mondiale. Direttore della Scuola Nazionale Speleosubacquea CNSAS. Corsi UTR e spedizioni.',
  image = '/images/og.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://albertocavedon.it');
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonicalURL} />
    <meta name="theme-color" content="#000000" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <slot name="head" />

    <!-- JSON-LD Person -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Alberto Cavedon",
      "jobTitle": "Speleologo subacqueo, Direttore Scuola Nazionale Speleosubacquea CNSAS",
      "url": canonicalURL.origin,
      "sameAs": ["https://www.speleosubtek.com", "https://www.facebook.com/p/speleosubit-Alberto-Cavedon-100066547968023/"],
      "address": { "@type": "PostalAddress", "addressLocality": "Valstagna", "addressRegion": "Vicenza", "addressCountry": "IT" }
    })} />
  </head>
  <body>

    <!-- Nav Apple style -->
    <header class="nav-apple" x-data="{ open: false }">
      <nav class="w-full max-w-6xl mx-auto px-6 flex items-center justify-between" aria-label="Navigazione">
        <a href="/" class="text-sm font-semibold text-white hover:text-apple-grey transition-colors tracking-wide">
          Alberto Cavedon
        </a>

        <!-- Desktop -->
        <ul class="hidden md:flex items-center gap-8 text-xs font-medium text-apple-grey" role="list">
          <li><a href="/about" class={`hover:text-white transition-colors ${currentPath.startsWith('/about') ? 'text-white' : ''}`}>Chi sono</a></li>
          <li><a href="/esperienze" class={`hover:text-white transition-colors ${currentPath.startsWith('/esperienze') ? 'text-white' : ''}`}>Esplorazioni</a></li>
          <li><a href="/corsi" class={`hover:text-white transition-colors ${currentPath.startsWith('/corsi') ? 'text-white' : ''}`}>Corsi UTR</a></li>
          <li><a href="/gallery" class={`hover:text-white transition-colors ${currentPath.startsWith('/gallery') ? 'text-white' : ''}`}>Gallery</a></li>
          <li><a href="/blog" class={`hover:text-white transition-colors ${currentPath.startsWith('/blog') ? 'text-white' : ''}`}>Blog</a></li>
          <li>
            <a href="/contatti" class={`text-xs font-semibold transition-colors ${currentPath.startsWith('/contatti') ? 'text-white' : 'text-apple-blue hover:text-apple-blue-hover'}`}>
              Contatti
            </a>
          </li>
        </ul>

        <!-- Mobile -->
        <button
          @click="open = !open"
          class="md:hidden text-apple-grey hover:text-white transition-colors p-1"
          :aria-expanded="open.toString()"
          aria-label="Menu"
        >
          <svg x-show="!open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg x-show="open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </nav>

      <!-- Mobile menu -->
      <div
        x-show="open"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0 -translate-y-2"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="absolute top-14 inset-x-0 bg-black/95 backdrop-blur-xl border-t border-white/10 md:hidden"
      >
        <ul class="flex flex-col px-6 py-6 gap-5 text-sm font-medium" role="list">
          <li><a href="/about" @click="open=false" class={`hover:text-white transition-colors block ${currentPath.startsWith('/about') ? 'text-white' : 'text-apple-grey'}`}>Chi sono</a></li>
          <li><a href="/esperienze" @click="open=false" class={`hover:text-white transition-colors block ${currentPath.startsWith('/esperienze') ? 'text-white' : 'text-apple-grey'}`}>Esplorazioni</a></li>
          <li><a href="/corsi" @click="open=false" class={`hover:text-white transition-colors block ${currentPath.startsWith('/corsi') ? 'text-white' : 'text-apple-grey'}`}>Corsi UTR</a></li>
          <li><a href="/gallery" @click="open=false" class={`hover:text-white transition-colors block ${currentPath.startsWith('/gallery') ? 'text-white' : 'text-apple-grey'}`}>Gallery</a></li>
          <li><a href="/blog" @click="open=false" class={`hover:text-white transition-colors block ${currentPath.startsWith('/blog') ? 'text-white' : 'text-apple-grey'}`}>Blog</a></li>
          <li><a href="/contatti" @click="open=false" class={`font-semibold block ${currentPath.startsWith('/contatti') ? 'text-white' : 'text-apple-blue'}`}>Contatti</a></li>
        </ul>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <!-- Footer Apple style -->
    <footer class="bg-apple-dark border-t border-white/10 pt-12 pb-8 mt-0">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid md:grid-cols-5 gap-8 pb-10 border-b border-white/10">
          <div class="md:col-span-1">
            <p class="text-sm font-semibold text-white mb-3">Alberto Cavedon</p>
            <p class="text-xs text-apple-grey leading-relaxed">
              Speleologo subacqueo.<br/>
              Direttore Scuola Nazionale<br/>
              Speleosubacquea CNSAS.
            </p>
          </div>
          <div>
            <p class="text-xs font-semibold text-white mb-3 uppercase tracking-wider">Esplora</p>
            <ul class="space-y-2 text-xs text-apple-grey">
              <li><a href="/about" class="hover:text-white transition-colors">Chi sono</a></li>
              <li><a href="/esperienze" class="hover:text-white transition-colors">Esplorazioni</a></li>
              <li><a href="/gallery" class="hover:text-white transition-colors">Gallery</a></li>
              <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
            </ul>
          </div>
          <div>
            <p class="text-xs font-semibold text-white mb-3 uppercase tracking-wider">Formazione</p>
            <ul class="space-y-2 text-xs text-apple-grey">
              <li><a href="/corsi#cave-base" class="hover:text-white transition-colors">Cave Diving Base</a></li>
              <li><a href="/corsi#utr-soccorso" class="hover:text-white transition-colors">UTR Soccorso</a></li>
              <li><a href="/corsi#deep-cave" class="hover:text-white transition-colors">Deep Cave Exploration</a></li>
              <li><a href="/corsi#seminario" class="hover:text-white transition-colors">Seminari</a></li>
            </ul>
          </div>
          <div>
            <p class="text-xs font-semibold text-white mb-3 uppercase tracking-wider">Certificazioni</p>
            <ul class="space-y-2 text-xs text-apple-grey">
              <li>UTRtek ISO International</li>
              <li>CNSAS Speleosubacquea</li>
              <li>Scuola Nazionale Speleosubacquea</li>
            </ul>
          </div>
          <div>
            <p class="text-xs font-semibold text-white mb-3 uppercase tracking-wider">Contatti</p>
            <ul class="space-y-2 text-xs text-apple-grey">
              <li><a href="mailto:info@speleosubtek.com" class="hover:text-white transition-colors">info@speleosubtek.com</a></li>
              <li><a href="https://www.speleosubtek.com" target="_blank" rel="noopener" class="hover:text-white transition-colors">speleosubtek.com</a></li>
              <li><a href="/contatti" class="hover:text-white transition-colors">Modulo di contatto</a></li>
            </ul>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row items-center justify-between pt-6 gap-3">
          <p class="text-xs text-apple-grey">Copyright © {new Date().getFullYear()} Alberto Cavedon. Tutti i diritti riservati.</p>
          <div class="flex gap-4 text-xs text-apple-grey">
            <a href="/privacy" class="hover:text-white transition-colors">Privacy</a>
            <a href="/contatti" class="hover:text-white transition-colors">Contatti</a>
          </div>
        </div>
      </div>
    </footer>

  <!-- Lenis smooth scroll + global 3D card tilt -->
  <script>
    import Lenis from 'lenis';
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    // Smooth scroll
    const lenis = new Lenis({ lerp: 0.08, smoothWheel: true });
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add(time => lenis.raf(time * 1000));
    gsap.ticker.lagSmoothing(0);

    // 3D tilt effect on all .card-apple elements
    function initTilt() {
      document.querySelectorAll<HTMLElement>('.card-apple, .tilt-3d').forEach(card => {
        card.style.transformStyle = 'preserve-3d';
        card.style.transition = 'transform 0.1s ease-out, box-shadow 0.3s ease';

        card.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = card.getBoundingClientRect();
          const cx = rect.left + rect.width  / 2;
          const cy = rect.top  + rect.height / 2;
          const dx = (e.clientX - cx) / (rect.width  / 2);
          const dy = (e.clientY - cy) / (rect.height / 2);
          const rotX = -dy * 8;
          const rotY =  dx * 8;
          card.style.transform = `perspective(800px) rotateX(${rotX}deg) rotateY(${rotY}deg) scale3d(1.02,1.02,1.02)`;
          card.style.boxShadow = `${-dx * 12}px ${-dy * 12}px 40px rgba(0,163,224,0.2)`;
        });

        card.addEventListener('mouseleave', () => {
          card.style.transform = 'perspective(800px) rotateX(0deg) rotateY(0deg) scale3d(1,1,1)';
          card.style.boxShadow = '';
        });
      });
    }

    // Init after DOM ready + re-init on navigation
    document.addEventListener('DOMContentLoaded', initTilt);
    document.addEventListener('astro:page-load', initTilt);
  </script>
  </body>
</html>
