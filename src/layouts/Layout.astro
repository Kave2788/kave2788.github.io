---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
}

const {
  title,
  description = 'Alberto Cavedon — speleologia subacquea, esplorazione, soccorso e formazione tecnica.',
  image = '/images/cave-archive-hero.webp',
  imageAlt = 'Illustrazione editoriale di un subacqueo in una grotta sommersa',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://kave2788.github.io');
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isCurrent = (href: string) => href === '/'
  ? currentPath === '/'
  : currentPath.startsWith(href);

const nav = [
  { href: '/about', label: 'Profilo' },
  { href: '/esperienze', label: 'Esplorazioni' },
  { href: '/corsi', label: 'Formazione' },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Alberto Cavedon',
  description: 'Speleosubacqueo, esploratore e formatore tecnico italiano.',
  url: canonicalURL.origin,
  sameAs: [
    'https://www.speleosubtek.com',
    'https://www.facebook.com/p/speleosubit-Alberto-Cavedon-100066547968023/',
  ],
  homeLocation: {
    '@type': 'Place',
    name: 'Canale di Brenta, Vicenza, Italia',
  },
};
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#080b0c" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, canonicalURL.origin)} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Vai al contenuto</a>

    <header class="site-header">
      <div class="site-header__inner shell">
        <a class="brand" href="/" aria-label="Alberto Cavedon — home">
          <svg class="brand__mark" viewBox="0 0 42 42" aria-hidden="true">
            <circle cx="21" cy="21" r="18.5" />
            <path d="M7 28c8-10 14-13 28-14M8 33c9-8 17-10 27-9" />
            <circle cx="29.5" cy="14.5" r="2.2" class="brand__beacon" />
          </svg>
          <span class="brand__copy">
            <strong>Alberto Cavedon</strong>
            <small>Archivio sommerso</small>
          </span>
        </a>

        <nav class="desktop-nav" aria-label="Navigazione principale">
          <ul>
            {nav.map(item => (
              <li>
                <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
          <a class="header-cta" href="/contatti">Contatti</a>
        </nav>

        <details class="mobile-nav">
          <summary aria-label="Apri il menu">
            <span></span><span></span>
          </summary>
          <nav aria-label="Navigazione mobile">
            <ul>
              {nav.map(item => (
                <li>
                  <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
                    {item.label}
                  </a>
                </li>
              ))}
              <li><a href="/contatti">Contatti</a></li>
            </ul>
          </nav>
        </details>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="shell site-footer__grid">
        <div class="site-footer__intro">
          <p class="eyebrow">AC / Archivio sommerso</p>
          <p class="site-footer__statement">Esplorare significa preparare, misurare, documentare e tornare.</p>
        </div>
        <div>
          <p class="footer-label">Percorsi</p>
          <ul class="footer-links">
            <li><a href="/about">Profilo</a></li>
            <li><a href="/esperienze">Esplorazioni</a></li>
            <li><a href="/corsi">Formazione</a></li>
          </ul>
        </div>
        <div>
          <p class="footer-label">Riferimenti</p>
          <ul class="footer-links">
            <li><a href="https://www.speleosubtek.com" target="_blank" rel="noopener">Speleosubtek <span aria-hidden="true">↗</span></a></li>
            <li><a href="https://news.cnsas.it" target="_blank" rel="noopener">CNSAS News <span aria-hidden="true">↗</span></a></li>
            <li><a href="/esperienze">Fonti e media</a></li>
          </ul>
        </div>
        <div>
          <p class="footer-label">Contatto diretto</p>
          <a class="footer-mail" href="mailto:info@speleosubtek.com">info@speleosubtek.com</a>
          <p class="footer-note">Per corsi, progetti, interviste e collaborazioni.</p>
        </div>
      </div>
      <div class="shell site-footer__bottom">
        <p>© {new Date().getFullYear()} Alberto Cavedon</p>
        <p><a href="/privacy">Privacy</a></p>
      </div>
    </footer>

    <script>
      const menus = document.querySelectorAll<HTMLDetailsElement>('.mobile-nav');
      menus.forEach(menu => {
        menu.querySelectorAll('a').forEach(link => link.addEventListener('click', () => {
          menu.open = false;
        }));
      });
    </script>
  </body>
</html>
