---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Pagina non trovata — Alberto Cavedon"
  description="La pagina richiesta non fa parte dell'archivio."
>
  <section class="not-found">
    <div class="shell not-found__grid">
      <div>
        <p class="eyebrow">Errore / 404</p>
        <h1 class="display-title">Fuori dal<br /><span class="text-accent">rilievo.</span></h1>
        <p class="lead">Questa traccia non porta a una pagina dell’archivio. Torna a un ingresso conosciuto.</p>
        <div class="button-row">
          <a class="button" href="/">Torna alla home</a>
          <a class="button-secondary" href="/esperienze">Apri l’atlante</a>
        </div>
      </div>
      <div class="not-found__signal" aria-hidden="true"><span>404</span></div>
    </div>
  </section>
</Layout>

<style>
  .not-found { display: grid; min-height: 90svh; align-items: center; padding-top: 7rem; }
  .not-found__grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(260px, 0.7fr); gap: clamp(3rem, 8vw, 8rem); align-items: center; }
  .not-found .lead { margin-block: 1.5rem 2rem; }
  .not-found__signal { display: grid; aspect-ratio: 1; place-items: center; color: var(--cyan); background: repeating-radial-gradient(ellipse at center, transparent 0 25px, rgba(117, 229, 255, 0.16) 26px 27px); border: 1px solid var(--line); border-radius: 50%; transform: scaleY(0.62); }
  .not-found__signal span { font-family: var(--font-display); font-size: clamp(6rem, 15vw, 12rem); font-weight: 800; transform: scaleY(1.6); }
  @media (max-width: 720px) { .not-found__grid { grid-template-columns: 1fr; } .not-found__signal { max-width: 22rem; } }
</style>
