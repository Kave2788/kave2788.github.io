---
import Layout from '../layouts/Layout.astro';

const timeline = [
  {
    year: '2000—2011',
    title: 'Il ramo profondo di Fontanazzi',
    text: 'Un report GUE del 2017 attribuisce ad Alberto Cavedon e al suo gruppo l’estensione dell’esplorazione del ramo profondo fino a quota −120 metri.',
    source: 'https://www.gue.com/files/annualreports/2017-Project-Reports.pdf',
    sourceLabel: 'GUE Project Report 2017',
  },
  {
    year: '2008',
    title: 'Elefante Bianco · intervento CNSAS',
    text: 'Durante il recupero di uno speleosub, Alberto guida la ricerca del ROV, bonifica e risagola il tratto operativo con visibilità estremamente ridotta.',
    source: 'https://www.cnsas.it/wp-content/uploads/2017/05/aprile-2008.pdf',
    sourceLabel: 'Il Soccorso Alpino · aprile 2008',
  },
  {
    year: '2010',
    title: 'Su Gologone · −135 metri',
    text: 'La spedizione porta il limite conosciuto della risorgenza sarda a 135 metri di profondità. Il risultato è riportato da fonti istituzionali e locali.',
    source: 'https://idese.cultura.gov.it/en/place/su-gologone/',
    sourceLabel: 'Istituto Centrale Patrimonio Immateriale',
  },
  {
    year: '2012',
    title: 'Arma del Lupo · nuovo ramo',
    text: 'Una spedizione sostenuta da 62 speleologi documenta 300 metri di nuove gallerie. L’immersione di Alberto dura 135 minuti e raggiunge quota −121 metri.',
    source: 'https://www.speleosubtek.com/archivio/esplorazioni-e-spedizioni/',
    sourceLabel: 'Archivio Speleosubtek',
  },
  {
    year: '2018',
    title: 'Procedure europee di soccorso',
    text: 'CNSAS documenta Alberto come direttore della Scuola nazionale speleosubacquea durante il lavoro con squadre europee per uniformare le procedure post-sifone.',
    source: 'https://news.cnsas.it/soccorso-speleosubacqueo-verso-un-codice-europeo-di-intervento/',
    sourceLabel: 'CNSAS News',
  },
  {
    year: '2025',
    title: 'Trent’anni di esperienza, raccontati',
    text: 'Nel podcast ScubaMed affronta la decompressione in ambiente ostruito e le decisioni che distinguono la grotta da un profilo di risalita lineare.',
    source: 'https://music.amazon.com.br/podcasts/851e8a18-9358-4969-a3f2-7a8cf6a215b1/episodes/5bb8cf95-a545-4795-bb71-032d6de3fdd8/scubamed-scuba-stories-in-grotta-con-alberto-cavedon',
    sourceLabel: 'ScubaMed · Scuba Stories',
  },
];

const qualifications = [
  { title: 'Professional Trimix Instructor', detail: 'Percorso fino a 100 m · ISO 24802-2', status: 'Validità dichiarata 2026' },
  { title: 'Technical Cave Instructor', detail: 'Formazione cave diving · ISO 24802-2', status: 'Validità dichiarata 2026' },
  { title: 'Professional CCR Rebreather', detail: 'Circuito chiuso fino a 100 m · ISO 24807', status: 'Rilascio dichiarato 2024' },
  { title: 'BLS-D & RCP Instructor', detail: 'Medical First Aid · ISO 24802-2', status: 'Validità dichiarata 2026' },
];
---

<Layout
  title="Profilo — Alberto Cavedon"
  description="Il profilo documentato di Alberto Cavedon: esplorazioni speleosubacquee, soccorso CNSAS e formazione tecnica."
>
  <header class="page-hero">
    <div class="shell page-hero__grid">
      <div class="hero-animate">
        <p class="eyebrow">Profilo / Alberto Cavedon</p>
        <h1 class="display-title">La competenza<br />prima del <span class="text-accent">limite.</span></h1>
      </div>
      <div class="page-hero__aside hero-animate hero-animate--delay">
        <p class="lead">Speleosubacqueo, formatore tecnico e già direttore della Scuola nazionale speleosubacquea CNSAS.</p>
        <p class="meta">Canale di Brenta · Vicenza · Italia</p>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="shell profile-grid">
      <div class="profile-plate" aria-hidden="true">
        <span>AC</span>
        <div class="profile-plate__axis"><i>0</i><i>−40</i><i>−80</i><i>−120</i></div>
        <p>Speleologia<br />subacquea</p>
      </div>
      <div class="profile-copy">
        <p class="eyebrow">Territorio / Metodo</p>
        <h2 class="display-xl">Una storia costruita dentro il carsismo vicentino.</h2>
        <div class="prose">
          <p>
            Alberto opera nel Canale di Brenta, nel territorio di Vicenza: una geografia in cui
            altopiano, risorgenze e grotte non sono sfondo, ma scuola quotidiana. Da qui nasce un
            percorso che unisce esplorazione, rilievo, formazione e soccorso.
          </p>
          <p>
            Le spedizioni più note non sono imprese individuali. Su Gologone, Arma del Lupo,
            Fontanazzi e l’Elefante Bianco mostrano lo stesso schema: squadre numerose, logistica,
            tecnici in superficie, materiali ridondanti e responsabilità distribuite.
          </p>
          <p>
            Anche la didattica segue questa logica. L’obiettivo non è consegnare rapidamente un
            livello, ma capire se controllo, configurazione e capacità decisionale sono già adatti
            all’ambiente successivo.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--paper">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow eyebrow--dark">Principi / 01</p>
          <h2 class="display-xl">Tre cose che vengono prima.</h2>
        </div>
        <p class="lead lead--dark">Prima della profondità, prima dell’attrezzatura, prima del brevetto.</p>
      </div>
      <div class="card-grid">
        <article class="card card--paper">
          <div class="card-index"><span>01</span><span>Preparazione</span></div>
          <h3>Il margine si costruisce a terra.</h3>
          <p>Pianificazione, ripetizione e conoscenza della configurazione riducono le decisioni improvvisate.</p>
        </article>
        <article class="card card--paper">
          <div class="card-index"><span>02</span><span>Squadra</span></div>
          <h3>Nessuna punta parte da sola.</h3>
          <p>Chi entra è solo la parte visibile di un sistema fatto di trasporti, gas, assistenza e rilievo.</p>
        </article>
        <article class="card card--paper">
          <div class="card-index"><span>03</span><span>Ritorno</span></div>
          <h3>Uscire è parte dell’esplorazione.</h3>
          <p>Ogni scelta viene letta nella direzione opposta: autonomia, decompressione e vie di recupero.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--surface" aria-labelledby="timeline-heading">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Cronologia / 02</p>
          <h2 id="timeline-heading" class="display-xl">Tracce verificabili.</h2>
        </div>
        <p class="lead">Una cronologia prudente: entra soltanto ciò che oggi può essere collegato a un documento pubblico.</p>
      </div>

      <ol class="timeline">
        {timeline.map(item => (
          <li>
            <time>{item.year}</time>
            <div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
            <a class="source-link" href={item.source} target="_blank" rel="noopener">
              {item.sourceLabel} <span aria-hidden="true">↗</span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section" aria-labelledby="qualifiche-heading">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Formazione / 03</p>
          <h2 id="qualifiche-heading" class="display-xl">Qualifiche dichiarate.</h2>
        </div>
        <p class="lead">
          Sintesi dei certificati UTRtek messi a disposizione per il sito. Codici personali e
          numeri di certificato non vengono pubblicati inutilmente.
        </p>
      </div>
      <div class="qualification-grid">
        {qualifications.map((item, index) => (
          <article class="qualification">
            <span class="qualification__index">0{index + 1}</span>
            <h3>{item.title}</h3>
            <p>{item.detail}</p>
            <span class="status status--review">{item.status}</span>
          </article>
        ))}
      </div>
      <div class="qualification-note">
        <p>Per enti, organizzatori e allievi è possibile richiedere verifica documentale diretta prima dell’attività.</p>
        <a class="button-secondary" href="/contatti?argomento=qualifiche">Richiedi una verifica</a>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="shell profile-cta">
      <div>
        <p class="eyebrow">Passo successivo</p>
        <h2 class="display-xl">Dalla biografia al percorso.</h2>
      </div>
      <div class="button-row">
        <a class="button" href="/esperienze">Apri l’atlante</a>
        <a class="button-secondary" href="/corsi">Esplora la formazione</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .profile-grid {
    display: grid;
    grid-template-columns: minmax(280px, 0.78fr) minmax(0, 1.22fr);
    gap: clamp(2.5rem, 8vw, 8rem);
    align-items: start;
  }

  .profile-plate {
    position: sticky;
    top: 7rem;
    display: grid;
    min-height: 38rem;
    align-content: space-between;
    padding: clamp(1.5rem, 4vw, 3rem);
    overflow: hidden;
    background:
      radial-gradient(circle at 75% 22%, rgba(117, 229, 255, 0.28), transparent 14%),
      repeating-radial-gradient(ellipse at 75% 22%, transparent 0 23px, rgba(117, 229, 255, 0.1) 24px 25px),
      var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
  }

  .profile-plate > span {
    color: var(--cyan);
    font-family: var(--font-display);
    font-size: clamp(8rem, 18vw, 15rem);
    font-weight: 800;
    letter-spacing: -0.08em;
    line-height: 0.7;
  }

  .profile-plate > p {
    margin: 0;
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .profile-plate__axis {
    position: absolute;
    top: 3rem;
    right: 1.5rem;
    bottom: 3rem;
    display: grid;
    align-content: space-between;
    padding-left: 0.8rem;
    color: var(--mist);
    border-left: 1px solid var(--line-strong);
    font-family: var(--font-mono);
    font-size: 0.6rem;
  }

  .profile-copy { padding-top: 2rem; }
  .profile-copy .display-xl { margin-bottom: 2rem; }

  .timeline {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--line);
  }

  .timeline li {
    display: grid;
    grid-template-columns: 8rem minmax(0, 1fr) minmax(12rem, 0.42fr);
    gap: clamp(1rem, 4vw, 3.5rem);
    align-items: start;
    padding-block: 1.6rem;
    border-bottom: 1px solid var(--line);
  }

  .timeline time {
    color: var(--cyan);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
  }

  .timeline h3 {
    margin-bottom: 0.5rem;
    font-family: var(--font-display);
    font-size: 1.65rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .timeline p { margin: 0; color: var(--mist); }

  .qualification-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }

  .qualification {
    min-height: 18rem;
    padding: clamp(1.25rem, 4vw, 2.5rem);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .qualification__index {
    display: block;
    margin-bottom: 3rem;
    color: var(--cyan);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .qualification h3 {
    margin-bottom: 0.65rem;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 1.5rem + 1vw, 2.6rem);
    line-height: 0.95;
    text-transform: uppercase;
  }

  .qualification p { color: var(--mist); }

  .qualification-note,
  .profile-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    margin-top: 2rem;
  }

  .qualification-note p { max-width: 42rem; margin: 0; color: var(--mist); }
  .profile-cta { margin-top: 0; }

  @media (max-width: 900px) {
    .profile-grid { grid-template-columns: 1fr; }
    .profile-plate { position: relative; top: auto; min-height: 30rem; }
    .timeline li { grid-template-columns: 6rem 1fr; }
    .timeline .source-link { grid-column: 2; }
  }

  @media (max-width: 640px) {
    .timeline li,
    .qualification-grid { grid-template-columns: 1fr; }
    .timeline .source-link { grid-column: auto; }
    .qualification-grid { border-left: 0; }
    .qualification { border-left: 1px solid var(--line); }
    .qualification-note,
    .profile-cta { align-items: stretch; flex-direction: column; }
  }
</style>
