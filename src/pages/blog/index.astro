---
import Layout from '../../layouts/Layout.astro';
import { archiveStories } from '../../data/archive';

const verifiedCount = archiveStories.filter((story) => story.status === 'Verificato').length;
const reviewCount = archiveStories.length - verifiedCount;
---

<Layout
  title="Archivio — Alberto Cavedon"
  description="Archivio delle esplorazioni legate ad Alberto Cavedon, con stato di verifica, dati essenziali e fonti pubbliche consultabili."
>
  <header class="page-hero archive-hero">
    <div class="shell page-hero__grid">
      <div>
        <p class="eyebrow">Archivio verificabile</p>
        <h1 class="display-title">Esplorazioni, documenti, fonti.</h1>
        <p class="lead">
          Ogni scheda separa i fatti documentati dalle informazioni ancora da controllare. Nessun racconto in prima persona viene attribuito ad Alberto senza una fonte primaria.
        </p>
      </div>
      <aside class="page-hero__aside" aria-label="Stato dell’archivio">
        <p class="meta">{archiveStories.length} schede pubblicate</p>
        <p>{verifiedCount} verificate · {reviewCount} in revisione</p>
      </aside>
    </div>
  </header>

  <section class="section archive-section" aria-labelledby="archive-list-heading">
    <div class="shell">
      <header class="section-heading">
        <div>
          <p class="eyebrow">Indice</p>
          <h2 id="archive-list-heading" class="display-lg">Schede dell’archivio</h2>
        </div>
        <p>Le voci verificate sono presentate per prime; le note incomplete restano visibili e dichiarano quali prove mancano.</p>
      </header>

      <div class="card-grid archive-grid">
        {archiveStories.map((story) => {
          const statusClass = story.status === 'Verificato'
            ? 'status status-badge status-badge--verified'
            : 'status status--review status-badge status-badge--review';

          return (
            <article class="archive-card" data-status={story.status}>
              <div class="archive-card__meta">
                <span class={statusClass}>Stato: {story.status}</span>
                {story.dateISO ? <time datetime={story.dateISO}>{story.dateLabel}</time> : <span>{story.dateLabel}</span>}
              </div>

              <p class="eyebrow">{story.category} · {story.place}</p>
              <h2 class="archive-card__title">
                <a href={`/blog/${story.slug}`}>{story.title}</a>
              </h2>
              <p class="archive-card__summary">{story.summary}</p>

              <dl class="archive-card__facts">
                {story.facts.slice(0, 3).map((fact) => (
                  <div>
                    <dt>{fact.label}</dt>
                    <dd>{fact.value}</dd>
                  </div>
                ))}
              </dl>

              <footer class="archive-card__footer">
                <span>{story.sources.length} {story.sources.length === 1 ? 'fonte pubblica' : 'fonti pubbliche'}</span>
                <a class="text-link archive-card__link" href={`/blog/${story.slug}`}>Apri la scheda</a>
              </footer>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section section--surface archive-method" aria-labelledby="archive-method-heading">
    <div class="shell">
      <p class="eyebrow">Metodo</p>
      <h2 id="archive-method-heading" class="display-lg">Come leggere lo stato delle schede</h2>
      <div class="card-grid method-grid">
        <article class="card">
          <h3>Verificato</h3>
          <p>Il nucleo della scheda trova riscontro in una fonte istituzionale, tecnica o giornalistica consultabile. Le fonti sono elencate con il loro preciso ambito.</p>
        </article>
        <article class="card">
          <h3>In revisione</h3>
          <p>Il luogo o il tema sono documentati, ma mancano prove sufficienti per attribuire date, attività o risultati ad Alberto Cavedon. I dettagli non verificati non vengono pubblicati.</p>
        </article>
      </div>
    </div>
  </section>
</Layout>
