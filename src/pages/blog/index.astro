---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    slug: 'bue-marino-2020',
    date: 'Settembre 2020',
    title: 'Grotta del Bue Marino: la Sardegna non smette di stupire',
    excerpt: "Ritorno in Sardegna con il team speleosubtek per esplorare uno dei sistemi carsici più affascinanti dell'isola.",
    tag: 'Sardegna',
    readTime: '5 min',
  },
  {
    slug: 'su-gologone-2012',
    date: 'Giugno 2012',
    title: 'Di nuovo a Su Gologone: nuove esplorazioni nella risorgenza',
    excerpt: "Dopo il record del 2010 torno nella sorgente sarda con un team italo-svizzero per spingere ancora più in profondità nel cuore del Supramonte.",
    tag: 'Sardegna',
    readTime: '6 min',
  },
  {
    slug: 'arma-del-lupo',
    date: 'Gennaio 2012',
    title: 'Arma del Lupo: tre ore dentro la montagna, –121 m',
    excerpt: "Una delle immersioni più lunghe della mia carriera: tre ore di navigazione prima di raggiungere la zona inesplorata. Cosa ho trovato e cosa ho imparato.",
    tag: 'Cave Diving',
    readTime: '8 min',
  },
  {
    slug: 'su-gologone-2010',
    date: 'Maggio 2010',
    title: 'Su Gologone 2010: come ho superato il record di Olivier Isler',
    excerpt: "Dieci giorni di spedizione. Tre anni di preparazione. –135 m. La storia completa dell'esplorazione che ha riscritto le mappe di una delle sorgenti più profonde d'Italia.",
    tag: 'Record',
    readTime: '12 min',
  },
  {
    slug: 'elefante-bianco-300',
    date: 'Estate 2009',
    title: "300 immersioni nell'Elefante Bianco: cosa mi ha insegnato",
    excerpt: "Una grotta che conosco centimetro per centimetro. Eppure continua a sorprendermi. Riflessioni dopo trecento discese.",
    tag: 'Elefante Bianco',
    readTime: '7 min',
  },
  {
    slug: 'vrelo-bune',
    date: 'Anni 2000',
    title: 'Vrelo Bune: una sorgente ai confini del mondo sommerso',
    excerpt: "Le grotte carsiche della Bosnia-Erzegovina, visibilità oltre 40 m, stalattiti sommerse. Un sistema che ti lascia senza parole.",
    tag: 'Bosnia',
    readTime: '5 min',
  },
];
---

<Layout
  title="Blog — Alberto Cavedon"
  description="Diario di immersioni e articoli tecnici di Alberto Cavedon: cave diving, speleologia, CNSAS, UTR."
>

  <section class="section-dark pt-40 pb-20 text-center">
    <p class="label-eyebrow mb-4">Diario</p>
    <h1 class="display-xl text-white mb-4">Blog &<br/><span class="text-ocean-blue">Log.</span></h1>
    <p class="body-lg max-w-xl mx-auto">Storie dall'abisso, guide tecniche e riflessioni.</p>
    <div class="flex justify-center gap-12 mt-12">
      <div>
        <p class="text-ocean-blue font-bold text-3xl">6</p>
        <p class="text-apple-grey text-xs mt-1 uppercase tracking-widest">Post</p>
      </div>
      <div>
        <p class="text-ocean-blue font-bold text-3xl">30+</p>
        <p class="text-apple-grey text-xs mt-1 uppercase tracking-widest">Anni di attività</p>
      </div>
      <div>
        <p class="text-ocean-blue font-bold text-3xl">40+</p>
        <p class="text-apple-grey text-xs mt-1 uppercase tracking-widest">Grotte esplorate</p>
      </div>
    </div>
  </section>

  <section class="section-mid py-16">
    <div class="max-w-3xl mx-auto px-6 space-y-4">
      {posts.map((p, i) => (
        <article class="card-apple group fade-up">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-xs bg-apple-blue/20 text-ocean-blue px-3 py-1 rounded-full font-semibold">{p.tag}</span>
            <span class="text-apple-grey text-xs">{p.date}</span>
            <span class="text-apple-grey/40 text-xs">· {p.readTime}</span>
          </div>
          <h2 class="text-white font-semibold text-xl mb-3 leading-snug group-hover:text-ocean-blue transition-colors">
            <a href={`/blog/${p.slug}`}>{p.title}</a>
          </h2>
          <p class="text-apple-grey text-sm mb-4 leading-relaxed">{p.excerpt}</p>
          <a href={`/blog/${p.slug}`} class="text-apple-blue text-sm font-semibold hover:underline">
            Leggi tutto →
          </a>
        </article>
      ))}
      <div class="mt-8 text-center">
        <a href="/esperienze" class="text-apple-blue text-sm hover:underline">← Torna alle esplorazioni</a>
      </div>
    </div>
  </section>

</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);
  gsap.utils.toArray<HTMLElement>('.fade-up').forEach(el => {
    gsap.fromTo(el, { opacity: 0, y: 40 }, {
      opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
      scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
    });
  });
</script>
