---
import Layout from '../layouts/Layout.astro';
import corsiRaw from '../data/corsi-utrtek.json';

// Raggruppa per categoria
const categorie = ['Ricreativo', 'Tecnico', 'Cave', 'Long Range', 'Rebreather', 'Professionale'];

const corsiPerCategoria = categorie.map(cat => ({
  cat,
  corsi: corsiRaw.filter(c => c.categoria === cat),
})).filter(g => g.corsi.length > 0);

const colori: Record<string, string> = {
  'Ricreativo':    'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
  'Tecnico':       'bg-ocean-blue/10 text-ocean-blue border-ocean-blue/20',
  'Cave':          'bg-amber-500/10 text-amber-400 border-amber-500/20',
  'Long Range':    'bg-purple-500/10 text-purple-400 border-purple-500/20',
  'Rebreather':    'bg-rose-500/10 text-rose-400 border-rose-500/20',
  'Professionale': 'bg-gold-400/10 text-gold-400 border-gold-400/20',
};

const descrizioni: Record<string, string> = {
  'Ricreativo':    'Brevetti per subacquei che vogliono esplorare in sicurezza fino a 40 m, con o senza decompressione.',
  'Tecnico':       'Programmi open circuit con aria, heliair e trimix fino a –100 m per chi vuole spingere i limiti.',
  'Cave':          'Immersione in ambienti confinati: grotte allagate, tecniche di navigazione e gestione filo guida.',
  'Long Range':    'Autonomia sott\'acqua da 100 a 240 minuti con configurazioni back-mount, side-mount e scooter.',
  'Rebreather':    'Sistema Mnemonic per ECCR e CCR: procedure standardizzate su Vision, rEvo, Hammerhead, Poseidon.',
  'Professionale': 'Percorsi per chi vuole guidare gruppi o diventare istruttore nel circuito UTRtek.',
};
---

<Layout
  title="Corsi UTRtek — Alberto Cavedon"
  description="Tutti i corsi UTRtek con Alberto Cavedon: ricreativo, tecnico, cave diving, long range, rebreather. Dati ufficiali utrtek.it."
>

  <!-- Hero -->
  <section class="section-dark pt-40 pb-24 text-center">
    <div class="max-w-4xl mx-auto px-6">
      <p class="label-eyebrow mb-4">Formazione ufficiale</p>
      <h1 class="display-xl text-white mb-6">Corsi <span class="text-ocean-blue">UTRtek</span></h1>
      <p class="body-lg max-w-2xl mx-auto mb-6">
        Tutti i brevetti del circuito <strong class="text-white">UTRtek — Underwater Technical Research</strong>,
        erogati da Alberto Cavedon con certificazione ISO International.
      </p>
      <a href="https://www.utrtek.it" target="_blank" rel="noopener"
         class="text-white/30 text-sm hover:text-ocean-blue transition-colors">
        Fonte: utrtek.it ↗
      </a>
    </div>
  </section>

  <!-- Unico x-data che governa sia la barra filtri che la section corsi -->
  <div x-data="{ active: 'Tutti' }">

    <!-- Filtri categoria (Alpine.js) -->
    <div class="sticky top-14 z-30 bg-apple-dark/80 backdrop-blur border-b border-white/5">
      <div class="max-w-6xl mx-auto px-6 py-3 flex gap-2 overflow-x-auto scrollbar-hide">
        {['Tutti', ...categorie].map(cat => (
          <button
            @click={`active = '${cat}'`}
            :class={`active === '${cat}' ? 'bg-ocean-blue text-white' : 'text-white/40 hover:text-white'`}
            class="whitespace-nowrap text-xs font-semibold px-4 py-1.5 rounded-full transition-colors border border-white/10 shrink-0"
          >
            {cat}
          </button>
        ))}
      </div>
    </div>

    <!-- Corsi per categoria -->
    <section class="section-mid py-16">
      <div class="max-w-6xl mx-auto px-6 space-y-16">
        {corsiPerCategoria.map(({ cat, corsi }) => (
          <div
            x-show={`active === 'Tutti' || active === '${cat}'`}
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 translate-y-2"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="fade-up"
          >

            <!-- Intestazione categoria -->
            <div class="flex items-center gap-4 mb-3">
              <span class={`text-xs font-bold px-3 py-1 rounded-full border ${colori[cat]}`}>
                {cat}
              </span>
              <div class="flex-1 h-px bg-white/10"></div>
              <span class="text-white/20 text-xs">{corsi.length} {corsi.length === 1 ? 'corso' : 'corsi'}</span>
            </div>
            <p class="text-white/40 text-sm mb-8">{descrizioni[cat]}</p>

            <!-- Grid corsi -->
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
              {corsi.map(corso => (
                <article id={corso.id} class="card-glass tilt-3d flex flex-col group">
                  <div class="flex items-start justify-between mb-4">
                    <p class="text-white/30 text-xs font-mono">{corso.codice}</p>
                    <div class="flex flex-col items-end gap-1">
                      {corso.profondita_max && (
                        <span class="text-xs font-mono text-ocean-blue bg-ocean-blue/10 px-2 py-0.5 rounded-full">
                          –{corso.profondita_max} m
                        </span>
                      )}
                      {corso.durata_min && (
                        <span class="text-xs font-mono text-purple-400 bg-purple-500/10 px-2 py-0.5 rounded-full">
                          {corso.durata_min}–{corso.durata_max} min
                        </span>
                      )}
                    </div>
                  </div>

                  <h2 class="text-white font-bold text-lg leading-tight mb-1 group-hover:text-ocean-blue transition-colors">
                    {corso.titolo}
                  </h2>
                  <p class="text-ocean-blue text-xs font-medium mb-3">{corso.sottotitolo}</p>
                  <p class="text-white/50 text-sm leading-relaxed flex-1 mb-5">{corso.descrizione}</p>

                  <div class="border-t border-white/10 pt-4 space-y-2">
                    <p class="text-white/30 text-xs">{corso.certificazione}</p>
                    {corso.prezzo_pik && (
                      <div class="flex items-center justify-between">
                        <span class="text-white/30 text-xs">PIK ufficiale</span>
                        <span class="text-gold-400 font-bold">€ {corso.prezzo_pik}</span>
                      </div>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>

  <!-- Nota UTRtek + CTA -->
  <section class="section-dark py-16">
    <div class="max-w-4xl mx-auto px-6 grid md:grid-cols-2 gap-8">
      <div class="card-glass">
        <p class="text-white font-semibold mb-3">Circuito UTRtek</p>
        <p class="text-white/50 text-sm leading-relaxed mb-4">
          UTRtek (Underwater Technical Research) è un'agenzia didattica internazionale con sede a Londra e ufficio a Milano.
          Certificazioni ISO, eCard digitali e badge stampati. Materiale didattico su <strong class="text-white">myutrtek.com</strong>.
        </p>
        <a href="https://www.utrtek.it" target="_blank" rel="noopener" class="text-ocean-blue text-sm hover:underline">
          utrtek.it ↗
        </a>
      </div>
      <div class="card-glass text-center flex flex-col items-center justify-center">
        <p class="text-white font-semibold mb-2">Vuoi iscriverti a un corso?</p>
        <p class="text-white/50 text-sm mb-5">Contattami per disponibilità, date e requisiti.</p>
        <a href="/contatti" class="btn-apple">Scrivimi</a>
        <a href="https://www.utrtek.it" target="_blank" rel="noopener"
           class="mt-3 text-white/40 text-xs hover:text-white transition-colors">
          o vedi tutti i corsi UTRtek ↗
        </a>
      </div>
    </div>
  </section>

</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);
  gsap.utils.toArray<HTMLElement>('.fade-up').forEach(el => {
    gsap.fromTo(el, { opacity: 0, y: 40 }, {
      opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
      scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' },
    });
  });
</script>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>
