---
import Layout from '../layouts/Layout.astro';

const media = [
  {
    type: 'Documentario',
    date: '2012 · 45 min',
    title: 'Su Gologone: dove la terra si spacca',
    text: 'Tre spedizioni, una squadra di quindici persone e il rilievo di una risorgenza ancora aperta.',
    href: 'https://vimeo.com/1164379037',
    source: 'Vimeo · Massimo D’Alessandro',
    accent: 'cyan',
  },
  {
    type: 'Podcast',
    date: '2025 · 28 min',
    title: 'Scuba Stories: in grotta con Alberto Cavedon',
    text: 'Una conversazione su decompressione, ambiente ostruito e decisioni in tempo reale.',
    href: 'https://music.amazon.com.br/podcasts/851e8a18-9358-4969-a3f2-7a8cf6a215b1/episodes/5bb8cf95-a545-4795-bb71-032d6de3fdd8/scubamed-scuba-stories-in-grotta-con-alberto-cavedon',
    source: 'ScubaMed · Amazon Music',
    accent: 'amber',
  },
  {
    type: 'Archivio fotografico',
    date: '2008—2024',
    title: 'Le gallerie Speleosubtek',
    text: 'Serie fotografiche pubblicate per spedizione e località. Restano sulla fonte originale per conservare contesto e provenienza.',
    href: 'https://www.speleosubtek.com/photogallery/',
    source: 'Speleosubtek',
    accent: 'bone',
  },
  {
    type: 'Pubblicazioni',
    date: 'Archivio tecnico',
    title: 'Dispense di speleologia subacquea',
    text: 'Sagolatura, configurazioni, incidenti, ricerca scientifica, DPV, rebreather e gestione dei gas.',
    href: 'https://www.speleosubtek.com/',
    source: 'Speleosubtek · documenti PDF',
    accent: 'cyan',
  },
  {
    type: 'Rivista',
    date: 'Maggio 2012',
    title: 'Intervista ad Alberto Cavedon',
    text: 'Una fonte editoriale del Club Alpino Italiano sul lavoro speleosubacqueo e sulle esplorazioni di quegli anni.',
    href: 'https://tecadigitale.cai.it/periodici/PDF/Montagne%20360/Montagne%20360_001_005_2012.pdf',
    source: 'CAI · Montagne360',
    accent: 'amber',
  },
  {
    type: 'Soccorso',
    date: '2018—2019',
    title: 'Verso un codice europeo di intervento',
    text: 'Il lavoro con squadre europee sulle procedure condivise per scenari traumatici oltre sifone.',
    href: 'https://news.cnsas.it/soccorso-speleosubacqueo-verso-un-codice-europeo-di-intervento/',
    source: 'CNSAS News',
    accent: 'bone',
  },
];
---

<Layout
  title="Media e fonti — Alberto Cavedon"
  description="Documentari, podcast, fotografie, pubblicazioni e fonti pubbliche sull'attività speleosubacquea di Alberto Cavedon."
>
  <header class="page-hero">
    <div class="shell page-hero__grid">
      <div class="hero-animate">
        <p class="eyebrow">Media / Fonti</p>
        <h1 class="display-title">Vedere il contesto.<br /><span class="text-accent">Conservare la fonte.</span></h1>
      </div>
      <div class="page-hero__aside hero-animate hero-animate--delay">
        <p class="lead">Niente fotografie generiche presentate come spedizioni reali. Ogni documento resta collegato al luogo in cui è stato pubblicato.</p>
        <p class="meta">Video · Audio · Fotografia · Stampa · Tecnica</p>
      </div>
    </div>
  </header>

  <section class="section media-feature">
    <div class="shell media-feature__grid">
      <figure class="identity-visual">
        <picture>
          <source srcset="/images/cave-archive-hero.avif" type="image/avif" />
          <img
            src="/images/cave-archive-hero.webp"
            alt="Illustrazione editoriale di un subacqueo in una grotta sommersa"
            width="1536"
            height="1024"
            loading="lazy"
          />
        </picture>
        <figcaption>
          <span>Visuale editoriale originale</span>
          <span>Non è documentazione di spedizione</span>
        </figcaption>
      </figure>
      <div>
        <p class="eyebrow">Identità / 01</p>
        <h2 class="display-xl">Una copertina, non una prova.</h2>
        <p class="lead">
          L’immagine principale è un’illustrazione creata per questo archivio. Non raffigura
          Alberto né una grotta specifica. Le fotografie reali vengono invece collegate alle
          raccolte originali, dove conservano data, sequenza e contesto.
        </p>
        <ul class="rule-list">
          <li><span>01</span><p>Illustrazioni dichiarate come tali.</p></li>
          <li><span>02</span><p>Nessuna attribuzione fotografica inventata.</p></li>
          <li><span>03</span><p>Materiali originali pubblicati con fonte e autorizzazione.</p></li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section section--surface" aria-labelledby="library-heading">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Raccolta / 02</p>
          <h2 id="library-heading" class="display-xl">L’archivio fuori dal sito.</h2>
        </div>
        <p class="lead">Sei ingressi a materiali già pubblicati. I collegamenti esterni si aprono sulla fonte originale.</p>
      </div>

      <div class="media-grid">
        {media.map((item, index) => (
          <article class={`media-card media-card--${item.accent}`}>
            <div class="media-card__top">
              <span>0{index + 1}</span>
              <span>{item.date}</span>
            </div>
            <div class="media-card__signal" aria-hidden="true"></div>
            <p class="media-card__type">{item.type}</p>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <a href={item.href} target="_blank" rel="noopener">
              {item.source} <span aria-hidden="true">↗</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--paper">
    <div class="shell contribute-grid">
      <div>
        <p class="eyebrow eyebrow--dark">Contribuisci / 03</p>
        <h2 class="display-xl">Hai una fotografia, un rilievo o un articolo?</h2>
      </div>
      <div>
        <p class="lead lead--dark">
          L’archivio cresce solo con materiali di provenienza chiara. Indica autore, data,
          luogo, persone presenti e condizioni d’uso: evitiamo di perdere il contesto una
          seconda volta.
        </p>
        <a class="button button--dark" href="/contatti?argomento=archivio">Proponi un documento</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .media-feature__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    gap: clamp(2.5rem, 8vw, 8rem);
    align-items: center;
  }

  .identity-visual {
    margin: 0;
    overflow: hidden;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
  }

  .identity-visual img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .identity-visual figcaption {
    display: flex;
    min-height: 58px;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.8rem 1rem;
    color: var(--mist);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .media-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .media-card {
    position: relative;
    display: flex;
    min-height: 34rem;
    padding: clamp(1.25rem, 3vw, 2rem);
    overflow: hidden;
    flex-direction: column;
    background: #0b0f10;
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .media-card__top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: var(--mist);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
  }

  .media-card__signal {
    position: relative;
    height: 9rem;
    margin-block: 2.4rem;
    overflow: hidden;
  }

  .media-card__signal::before,
  .media-card__signal::after {
    position: absolute;
    content: '';
    border-radius: 50%;
  }

  .media-card__signal::before {
    top: 50%;
    left: 50%;
    width: 12rem;
    height: 12rem;
    border: 1px solid currentColor;
    transform: translate(-50%, -50%) scaleY(0.32);
    box-shadow: 0 0 0 1.4rem rgba(255, 255, 255, 0.025), 0 0 0 2.8rem rgba(255, 255, 255, 0.02);
  }

  .media-card__signal::after {
    top: calc(50% - 4px);
    right: 18%;
    width: 8px;
    height: 8px;
    background: currentColor;
  }

  .media-card--cyan .media-card__signal { color: var(--cyan); }
  .media-card--amber .media-card__signal { color: var(--amber); }
  .media-card--bone .media-card__signal { color: var(--bone); }

  .media-card__type {
    margin-bottom: 0.7rem;
    color: var(--cyan);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .media-card h3 {
    margin-bottom: 0.75rem;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 1.45rem + 1vw, 2.5rem);
    line-height: 0.95;
    text-transform: uppercase;
  }

  .media-card > p:not(.media-card__type) { color: var(--mist); }

  .media-card > a {
    display: flex;
    min-height: 48px;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
    color: var(--bone);
    border-top: 1px solid var(--line);
    font-size: 0.78rem;
    font-weight: 700;
    text-decoration: none;
  }

  .media-card > a:hover { color: var(--cyan); }

  .contribute-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(300px, 0.95fr);
    gap: clamp(2.5rem, 8vw, 8rem);
    align-items: end;
  }

  @media (max-width: 940px) {
    .media-feature__grid,
    .contribute-grid { grid-template-columns: 1fr; }
    .media-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 620px) {
    .media-grid { grid-template-columns: 1fr; }
    .media-card { min-height: 30rem; }
    .identity-visual figcaption { align-items: flex-start; flex-direction: column; justify-content: center; }
  }
</style>
