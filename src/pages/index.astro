---
import Layout from '../layouts/Layout.astro';

const proof = [
  {
    value: '−135 m',
    label: 'Su Gologone · 2010',
    note: 'Limite esplorativo documentato',
    href: 'https://idese.cultura.gov.it/en/place/su-gologone/',
  },
  {
    value: '300+',
    label: 'Elefante Bianco',
    note: 'Immersioni riportate dal CNSAS nel 2008',
    href: 'https://www.cnsas.it/wp-content/uploads/2017/05/aprile-2008.pdf',
  },
  {
    value: '2018',
    label: 'Soccorso europeo',
    note: 'Procedure congiunte CNSAS · ECRA',
    href: 'https://news.cnsas.it/soccorso-speleosubacqueo-verso-un-codice-europeo-di-intervento/',
  },
];

const atlas = [
  {
    index: '01 / Sardegna',
    title: 'Su Gologone',
    metric: '−135 m',
    text: 'Nel 2010 la squadra estende il rilievo della risorgenza e porta il limite esplorato a 135 metri di profondità.',
    href: '/blog/su-gologone',
    status: 'Verificato',
  },
  {
    index: '02 / Piemonte',
    title: 'Arma del Lupo',
    metric: '135 min',
    text: 'Nel gennaio 2012 una spedizione di 62 speleologi sostiene una progressione di 300 metri nel sifone, fino alla quota massima di −121 metri.',
    href: '/blog/arma-del-lupo',
    status: 'Verificato',
  },
  {
    index: '03 / Veneto',
    title: 'Elefante Bianco',
    metric: '300+',
    text: 'Una grotta di riferimento nel Canale di Brenta: esplorazione, conoscenza del sistema e operazioni di soccorso.',
    href: '/blog/elefante-bianco-300',
    status: 'Verificato',
  },
];
---

<Layout
  title="Alberto Cavedon — Archivio sommerso"
  description="L'archivio di Alberto Cavedon: speleologia subacquea, esplorazioni documentate, soccorso e formazione tecnica."
>
  <section class="home-hero" aria-labelledby="hero-title">
    <picture class="home-hero__picture">
      <source srcset="/images/cave-archive-hero.avif" type="image/avif" />
      <img
        src="/images/cave-archive-hero.webp"
        alt="Illustrazione editoriale di un subacqueo lungo un filo guida in una grotta sommersa"
        width="1536"
        height="1024"
        fetchpriority="high"
      />
    </picture>
    <div class="home-hero__veil" aria-hidden="true"></div>
    <div class="home-hero__contours" aria-hidden="true"></div>

    <div class="shell home-hero__content">
      <div class="home-hero__copy hero-animate">
        <p class="eyebrow">Alberto Cavedon · Speleologia subacquea</p>
        <h1 id="hero-title" class="display-title">
          Sotto il<br />
          limite <span class="text-accent">visibile.</span>
        </h1>
        <p class="home-hero__lead">
          Esplorazione, soccorso e formazione tecnica raccontati attraverso dati,
          rilievi e fonti. Senza trasformare il rischio in spettacolo.
        </p>
        <div class="button-row">
          <a class="button" href="/esperienze">Apri le esplorazioni <span aria-hidden="true">↘</span></a>
          <a class="button-secondary" href="/corsi">Trova il tuo percorso</a>
        </div>
      </div>

      <div class="home-hero__depth hero-animate hero-animate--delay" aria-label="Scala di profondità illustrativa">
        <span>0 m</span>
        <span>−40</span>
        <span>−80</span>
        <strong>−135 m</strong>
      </div>
    </div>

    <p class="home-hero__caption">Visuale editoriale · non è documentazione di una spedizione reale</p>
  </section>

  <section class="proof-strip" aria-label="Dati documentati">
    <div class="shell stat-grid">
      {proof.map(item => (
        <a class="stat" href={item.href} target="_blank" rel="noopener" aria-label={`${item.value}, ${item.label}. Apri la fonte`}>
          <strong>{item.value}</strong>
          <span>{item.label}</span>
          <small>{item.note} <span aria-hidden="true">↗</span></small>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="shell manifesto-grid">
      <div>
        <p class="eyebrow">Metodo / 01</p>
        <h2 class="display-xl">L’abisso non è un primato.</h2>
      </div>
      <div class="manifesto-copy">
        <p class="lead">
          Una profondità da sola non racconta nulla. Dietro ogni metro ci sono studio,
          gas, configurazione, persone di supporto, rilievo e una via di ritorno.
        </p>
        <p>
          Questo sito nasce come archivio leggibile: distingue i fatti verificati dalle
          memorie ancora da validare e collega ogni passaggio importante alla sua fonte.
        </p>
        <a class="text-link" href="/about">Il profilo e il metodo <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <section class="section section--surface" aria-labelledby="atlas-heading">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Esplorazioni / 02</p>
          <h2 id="atlas-heading" class="display-xl">Tre ingressi nell’archivio.</h2>
        </div>
        <p class="lead">
          Non una collezione di record: luoghi, squadre, condizioni e documenti da leggere
          come parti dello stesso sistema.
        </p>
      </div>

      <div class="card-grid">
        {atlas.map(item => (
          <article class="archive-card home-atlas-card">
            <div class="card-index">
              <span>{item.index}</span>
              <span class="status">{item.status}</span>
            </div>
            <p class="home-atlas-card__metric">{item.metric}</p>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <a class="source-link" href={item.href}>Apri la scheda <span aria-hidden="true">→</span></a>
          </article>
        ))}
      </div>

      <div class="section-action">
        <a class="button-secondary" href="/esperienze">Vedi tutte le esplorazioni</a>
      </div>
    </div>
  </section>

  <section class="section section--paper" aria-labelledby="training-heading">
    <div class="shell feature-split">
      <div>
        <p class="eyebrow eyebrow--dark">Formazione / 03</p>
        <h2 id="training-heading" class="display-xl">Prima il subacqueo. Poi il corso.</h2>
        <p class="lead lead--dark">
          Certificazione precedente, configurazione, continuità di allenamento e obiettivo:
          il percorso giusto parte da qui, non dal nome del brevetto.
        </p>
        <div class="button-row">
          <a class="button button--dark" href="/corsi#orientamento">Fai il pre-orientamento</a>
          <a class="text-link training-link" href="/contatti">Parla direttamente con Alberto <span aria-hidden="true">→</span></a>
        </div>
      </div>
      <ol class="training-steps">
        <li><span>01</span><div><strong>Valutare</strong><p>Esperienza reale, assetto, controllo e frequenza in acqua.</p></div></li>
        <li><span>02</span><div><strong>Preparare</strong><p>Colmare prima le basi che il livello successivo dà già per acquisite.</p></div></li>
        <li><span>03</span><div><strong>Verificare</strong><p>La certificazione arriva quando gli standard sono dimostrati, non a calendario.</p></div></li>
      </ol>
    </div>
  </section>

  <section class="section" aria-labelledby="film-heading">
    <div class="shell film-grid">
      <div class="film-poster" aria-hidden="true">
        <span class="film-poster__depth">−135</span>
        <span class="film-poster__unit">metri</span>
        <div class="film-poster__line"></div>
      </div>
      <div>
        <p class="eyebrow">Documento / 04</p>
        <h2 id="film-heading" class="display-xl">Dove la terra si spacca.</h2>
        <p class="lead">
          Il documentario di Massimo D’Alessandro ricostruisce tre spedizioni a Su Gologone:
          preparazione, squadra, imprevisti e rilievo. Quarantacinque minuti per vedere ciò
          che un numero non può spiegare.
        </p>
        <p class="meta">Documentario · 2012 · 45 min · Italiano</p>
        <a class="button-secondary" href="https://vimeo.com/1164379037" target="_blank" rel="noopener">
          Guarda su Vimeo <span aria-hidden="true">↗</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="shell home-contact">
      <div>
        <p class="eyebrow">Contatto / 05</p>
        <h2 class="display-xl">Una domanda precisa apre la strada giusta.</h2>
      </div>
      <div>
        <p class="lead">Corsi, spedizioni, consulenze tecniche, interviste o materiale d’archivio.</p>
        <a class="button" href="/contatti">Prepara la richiesta <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .home-hero {
    position: relative;
    display: grid;
    min-height: 100svh;
    align-items: end;
    overflow: hidden;
    background: #050708;
  }

  .home-hero__picture,
  .home-hero__picture img,
  .home-hero__veil,
  .home-hero__contours {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .home-hero__picture img {
    object-fit: cover;
    object-position: 62% center;
  }

  .home-hero__veil {
    background:
      linear-gradient(90deg, rgba(5, 7, 8, 0.98) 0%, rgba(5, 7, 8, 0.88) 34%, rgba(5, 7, 8, 0.2) 73%, rgba(5, 7, 8, 0.45) 100%),
      linear-gradient(0deg, #050708 0%, transparent 30%, rgba(5, 7, 8, 0.1) 78%, rgba(5, 7, 8, 0.8) 100%);
  }

  .home-hero__contours {
    opacity: 0.15;
    background: repeating-radial-gradient(ellipse at 15% 56%, transparent 0 28px, rgba(117, 229, 255, 0.24) 29px 30px);
    transform: scale(1.3, 0.8) rotate(-8deg);
    transform-origin: left center;
  }

  .home-hero__content {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 8rem;
    gap: 2rem;
    align-items: end;
    padding-top: 9rem;
    padding-bottom: clamp(5rem, 9vw, 8rem);
  }

  .home-hero__copy { max-width: 58rem; }
  .home-hero__copy .display-title { max-width: 8ch; }

  .home-hero__lead {
    max-width: 42rem;
    margin-block: 1.75rem 2rem;
    color: #ccd4d1;
    font-size: clamp(1.04rem, 0.95rem + 0.45vw, 1.35rem);
  }

  .home-hero__depth {
    display: grid;
    align-content: space-between;
    min-height: 22rem;
    padding-left: 1rem;
    color: #c0ccca;
    border-left: 1px solid rgba(117, 229, 255, 0.55);
    font-family: var(--font-mono);
    font-size: 0.7rem;
  }

  .home-hero__depth span,
  .home-hero__depth strong { position: relative; }

  .home-hero__depth span::before,
  .home-hero__depth strong::before {
    position: absolute;
    top: 0.7em;
    left: -1rem;
    width: 0.55rem;
    height: 1px;
    content: '';
    background: var(--cyan);
  }

  .home-hero__depth strong {
    color: var(--cyan);
    font-size: 0.9rem;
  }

  .home-hero__caption {
    position: absolute;
    z-index: 3;
    right: 1rem;
    bottom: 1rem;
    margin: 0;
    color: rgba(241, 238, 229, 0.48);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .proof-strip { background: #050708; }

  .proof-strip .stat {
    color: inherit;
    text-decoration: none;
  }

  .proof-strip .stat small {
    display: block;
    margin-top: 0.85rem;
    color: rgba(174, 187, 184, 0.68);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    line-height: 1.5;
  }

  .proof-strip .stat:hover { background: rgba(117, 229, 255, 0.04); }

  .manifesto-grid,
  .home-contact {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(300px, 0.85fr);
    gap: clamp(2.5rem, 8vw, 8rem);
    align-items: start;
  }

  .manifesto-copy > p:not(.lead) { color: var(--mist); }

  .home-atlas-card { min-height: 29rem; }

  .home-atlas-card__metric {
    margin-bottom: 1.5rem;
    color: var(--cyan);
    font-family: var(--font-display);
    font-size: clamp(3rem, 2rem + 2.6vw, 5.2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 0.9;
  }

  .home-atlas-card .source-link {
    position: absolute;
    right: 2rem;
    bottom: 1.35rem;
    left: 2rem;
  }

  .section-action {
    display: flex;
    justify-content: flex-end;
    margin-top: 2rem;
  }

  .training-steps {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid rgba(8, 11, 12, 0.2);
  }

  .training-steps li {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1.25rem;
    padding-block: 1.3rem;
    border-bottom: 1px solid rgba(8, 11, 12, 0.2);
  }

  .training-steps > li > span {
    color: #087e98;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .training-steps strong {
    display: block;
    margin-bottom: 0.3rem;
    font-family: var(--font-display);
    font-size: 1.65rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .training-steps p { margin: 0; color: #465150; }
  .training-link { color: #087e98; }
  .training-link:hover { color: var(--ink); }

  .film-grid {
    display: grid;
    grid-template-columns: minmax(280px, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 8vw, 8rem);
    align-items: center;
  }

  .film-poster {
    position: relative;
    display: grid;
    min-height: clamp(30rem, 55vw, 42rem);
    align-content: end;
    padding: clamp(1.5rem, 5vw, 4rem);
    overflow: hidden;
    background:
      radial-gradient(circle at 70% 16%, rgba(117, 229, 255, 0.32), transparent 13%),
      repeating-radial-gradient(ellipse at 70% 16%, transparent 0 31px, rgba(117, 229, 255, 0.09) 32px 33px),
      linear-gradient(145deg, #152326, #060808 70%);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
  }

  .film-poster__depth {
    position: relative;
    z-index: 1;
    color: var(--cyan);
    font-family: var(--font-display);
    font-size: clamp(6rem, 12vw, 11rem);
    font-weight: 800;
    letter-spacing: -0.06em;
    line-height: 0.7;
  }

  .film-poster__unit {
    color: var(--bone);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .film-poster__line {
    position: absolute;
    top: 22%;
    right: -8%;
    width: 80%;
    height: 1px;
    background: var(--amber);
    transform: rotate(-27deg);
    transform-origin: right;
  }

  .home-contact { align-items: end; }

  @media (max-width: 900px) {
    .manifesto-grid,
    .film-grid,
    .home-contact { grid-template-columns: 1fr; }

    .film-poster { min-height: 32rem; }
  }

  @media (max-width: 640px) {
    .home-hero { min-height: 850px; }
    .home-hero__picture img { object-position: 68% center; }
    .home-hero__veil {
      background:
        linear-gradient(0deg, #050708 0%, rgba(5, 7, 8, 0.65) 48%, rgba(5, 7, 8, 0.46) 76%, rgba(5, 7, 8, 0.84) 100%),
        linear-gradient(90deg, rgba(5, 7, 8, 0.86), transparent 84%);
    }

    .home-hero__content {
      grid-template-columns: 1fr;
      padding-bottom: 5.5rem;
    }

    .home-hero__depth { display: none; }
    .home-hero__caption { right: 0.65rem; bottom: 0.65rem; left: 0.65rem; text-align: center; }
    .home-atlas-card { min-height: 25rem; }
  }
</style>
